# Example justfile for testing Jarvis Just integration
# See: https://github.com/casey/just

# @emoji 🔨
# @description Build the project in debug mode
build:
    @echo "🔨 Building project in debug mode..."
    @echo "   Compiling sources..."
    @echo "   Linking binaries..."
    @echo "✅ Build complete!"

# @emoji 🧪
# @description Run the test suite
test:
    @echo "🧪 Running test suite..."
    @echo "   Running unit tests... 42/42 passed"
    @echo "   Running integration tests... 8/8 passed"
    @echo "✅ All tests passed!"

# @emoji ✅
# @description Run linter and format checker
check:
    @echo "✅ Running linter..."
    @echo "   No warnings found."
    @echo "   Checking code format..."
    @echo "   All files are properly formatted."
    @echo "✅ Check passed!"

# @emoji 🧹
# @description Clean build artifacts
clean:
    @echo "🧹 Cleaning build artifacts..."
    @echo "   Removing target/ directory..."
    @echo "   Removing dist/ directory..."
    @echo "✅ Clean complete!"

# @emoji 📦
# @description Build optimized release binary
release:
    @echo "📦 Building optimized release binary..."
    @echo "   Optimizing with LTO..."
    @echo "   Stripping debug symbols..."
    @echo "✅ Release build complete! Binary at ./target/release/app"

# @emoji 🚀
# @description Deploy to the specified environment
deploy env="staging":
    @echo "🚀 Deploying to {{env}}..."
    @echo "   Uploading artifacts..."
    @echo "   Restarting services..."
    @echo "✅ Deployed to {{env}} successfully!"

# @emoji ❓
# @description Show available just recipes
help:
    @echo "Available recipes:"
    @just --list

# @emoji ✅
# @description Exit with code 0 — test success display in UI
exit_success:
    @echo "✅ This recipe exits successfully (code 0)."
    @exit 0

# @emoji ❌
# @description Exit with code 1 — test error/failure display in UI
exit_failure:
    @echo "❌ This recipe exits with an error (code 1)."
    @echo "   Jarvis should indicate this recipe failed."
    @exit 1

# @ignore
_internal_helper:
    @echo "This is an internal helper recipe (hidden from TUI)"
